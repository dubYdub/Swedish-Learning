  "customArticles": [
    {
      "id": "custom-1778623690101",
      "topic": "världen",
      "topicLabel": "Världen",
      "topicEmoji": "🌍",
      "difficulty": "A2",
      "title": "Kungskobran på Skansenakvariet har hittats",
      "summary": "The escaped king cobra at Skansenakvariet in Stockholm has been located inside a wall near its enclosure. Staff plan to cut a hole to capture it.",
      "keyVocab": [
        {
          "word": "djurskötare",
          "def": "animal keeper"
        },
        {
          "word": "rymde",
          "def": "escaped"
        },
        {
          "word": "giftig",
          "def": "poisonous"
        },
        {
          "word": "kungskobra",
          "def": "king cobra"
        },
        {
          "word": "väsa",
          "def": "hiss"
        },
        {
          "word": "fånga in",
          "def": "capture"
        },
        {
          "word": "botemedel",
          "def": "antidote"
        },
        {
          "word": "kvävas",
          "def": "suffocate"
        }
      ],
      "isCustom": true,
      "content": [
        {
          "id": "custom-1778624854092-1",
          "text": "Djurskötare har hittat den giftiga ormen som rymde från sin bur i lördags. Ormen är kvar på djurparken Skansenakvariet i Stockholm. Ormen är en kungskobra. Den är två och en halv meter lång och mycket giftig.",
          "translation": "Animal keepers have found the poisonous snake that escaped from its cage last Saturday. The snake is still at the Skansen Aquarium zoo in Stockholm. The snake is a king cobra. It is two and a half meters long and very poisonous."
        },
        {
          "id": "custom-1778624854092-2",
          "text": "Ormen är inne i en vägg nära sin bur. Djurskötarna har sett ormen med en speciell liten kamera. De har också hört kobran väsa. Det säger Skansenakvariets ägare Jonas Wahlström till P1 morgon.",
          "translation": "The snake is inside a wall near its cage. The animal keepers have seen the snake with a special small camera. They have also heard the cobra hiss. That's what Skansen Aquarium's owner Jonas Wahlström says to P1 Morning."
        },
        {
          "id": "custom-1778624854092-3",
          "text": "– Vi såg honom och hörde honom till och med väsa.",
          "translation": "– We saw him and even heard him hiss."
        },
        {
          "id": "custom-1778624854092-4",
          "text": "Nu ska de som jobbar i djurparken göra ett hål i väggen och försöka fånga in kobran.",
          "translation": "Now those who work at the zoo will make a hole in the wall and try to catch the cobra."
        },
        {
          "id": "custom-1778624854092-5",
          "text": "Kobran rymde från sin bur för nästan en vecka sedan. Händelsen har fått mycket uppmärksamhet både i Sverige och i andra länder. Flera medier i USA har till exempel rapporterat om ormen.",
          "translation": "The cobra escaped from its cage almost a week ago. The event has received a lot of attention both in Sweden and in other countries. Several media outlets in the USA, for example, have reported about the snake."
        },
        {
          "id": "custom-1778624854092-6",
          "text": "Kungskobran är världens längsta giftiga orm. Den kan bli fem och en halv meter lång. Om en människa blir biten av ormen måste hen få ett botemedel snabbt. Annars kan giftet döda personen inom en timme. Giftet gör att offret kvävs. Ormen i Stockholm har varit lös länge, men ingen har blivit skadad.",
          "translation": "The king cobra is the world's longest poisonous snake. It can become five and a half meters long. If a person is bitten by the snake, they must get an antidote quickly. Otherwise, the poison can kill the person within an hour. The poison causes the victim to suffocate. The snake in Stockholm has been loose for a long time, but no one has been injured."
        }
      ],
      "audioUrl": "https://lyssna-cdn.sr.se/isidor/2022/10/program_djurskotare_har_hittat_den_gif_20221028_1528286119_a96.m4a?_h_publicationId=8174692"
    },
